# Application Configuration
APP_URL=https://your-domain-here.com
ENVIRONMENT=production

# Database Configuration  
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/reservas_db
POSTGRES_DB=reservas_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
TIMEZONE=America/Santo_Domingo

# Frontend Configuration (auto-generated from APP_URL)
NEXT_PUBLIC_API_URL=${APP_URL}/api/v1

# Docker/Node Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1